# Django
SECRET_KEY=
DEBUG=
DEBUG_STORE=

# Database (PostgreSQL - if not set, falls back to SQLite)
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=

# Redis (optional - falls back to in-memory cache if not set)
REDIS_URI=

# Celery (برای reindex و taskهای background)
# مثال با Redis: redis://localhost:6379/1
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# S3 / Object Storage (optional - falls back to local storage if not set)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_STORAGE_BUCKET_NAME=
S3_CUSTOM_DOMAIN=
S3_ENDPOINT_URL=
S3_LOCATION=

# API URLs
API_URL_BASE=
WEBSITE_URL_BASE=

# SMS (optional - OTP prints to console if not set)
SMS_PANEL_API_KEY=

# Sentry (optional - commented in settings)
# SENTRY_DSN=

# ChromaDB (RAG / vector store)
CHROMA_MODE=persistent
CHROMA_PERSIST_PATH=./chroma_data
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Embedding (sentence-transformers or openai)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# OpenAI (for embeddings if openai, and for LLM chat)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Guide chat - محدودیت توکن برای جلوگیری از سوءاستفاده
# GUIDE_CHAT_MAX_INPUT_CHARS=8000   # مجموع کاراکتر ورودی (پرامپت + تاریخچه)
# GUIDE_CHAT_MAX_OUTPUT_TOKENS=500  # حداکثر توکن خروجی
# GUIDE_CHAT_MAX_MESSAGE_CHARS=2000 # حداکثر طول هر پیام کاربر
